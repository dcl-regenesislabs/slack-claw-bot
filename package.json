{
  "name": "slack-issue-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "DEBUG=true tsx watch src/index.ts",
    "cli": "tsx src/cli.ts",
    "build": "tsc --noEmit",
    "build:dist": "tsc",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@slack/bolt": "^4.1.0",
    "@tobilu/qmd": "^1.1.6",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
